# Plus-specific files that must not be overwritten when manually merging upstream.
# The 'ours' merge driver keeps our version on conflict during a manual upstream pull.
# Enable before merging: git config merge.ours.driver true
.github/workflows/plugin-version-guard.yml   merge=ours
.github/workflows/marketplace-version-guard.yml merge=ours
.github/workflows/claude-review.yml          merge=ours
